# --- App ---
APP_NAME=Gobron API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
PUBLIC_BASE_URL=http://localhost:8000

# --- Database (async driver) ---
DATABASE_URL=postgresql+asyncpg://gobron:gobron@localhost:5432/gobron

# --- JWT ---
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# --- Superadmin (created by: python -m app.seed) ---
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=kamoliddin

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:change-me-from-BotFather
TMA_URL=http://localhost:5173
TELEGRAM_INITDATA_MAX_AGE=86400

# --- OTP (dev fallback login) ---
OTP_LENGTH=6
OTP_EXPIRE_SECONDS=120
OTP_DEV_MODE=true
OTP_DEV_CODE=111111

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
