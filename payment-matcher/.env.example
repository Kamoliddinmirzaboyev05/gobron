# --- PostgreSQL (same DB as gobron-backend) ---
DATABASE_URL=postgresql://gobron:gobron@localhost:5432/gobron

# --- Telegram User API (https://my.telegram.org/apps) ---
# Optional fallbacks — prefer Superadmin → Humo to'lovlar UI (DB)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
TELEGRAM_PHONE=
# Cloud password (Two-Step Verification) — also settable in Superadmin UI
TELEGRAM_2FA_PASSWORD=

HUMO_BOT_USERNAME=HUMOcardbot
HUMO_BOT_EXTRA=

# Payment intent TTL (must match backend: 15 min)
PAYMENT_TTL_MINUTES=15

# Logging: debug | info | warn | error
LOG_LEVEL=info
