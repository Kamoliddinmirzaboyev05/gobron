# --- PostgreSQL (same DB as gobron-backend) ---
DATABASE_URL=postgresql://gobron:gobron@localhost:5432/gobron

# --- Telegram User API (https://my.telegram.org/apps) ---
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
# Session string produced on first login (or leave empty and log in interactively)
TELEGRAM_SESSION=
# Phone used only for the first interactive login
TELEGRAM_PHONE=+998901234567

# Humo notification bot username (without @) or numeric id
HUMO_BOT_USERNAME=humo_uz
# Optional: also accept messages from these usernames (comma-separated)
HUMO_BOT_EXTRA=

# Payment intent TTL (must match backend: 15 min)
PAYMENT_TTL_MINUTES=15

# Logging: debug | info | warn | error
LOG_LEVEL=info
